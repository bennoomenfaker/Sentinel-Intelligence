{
  "name": "sentinel-intelligence",
  "version": "1.0.0",
  "description": "Data Collection & AI Analytics Platform",
  "scripts": {
    "build": "cd backend && npm run build",
    "start": "cd backend && npm run start",
    "start:dev": "cd backend && npm run start:dev",
    "start:prod": "cd backend && npm run start:prod",
    "build:frontend": "cd frontend && npm run build",
    "start:frontend": "cd frontend && npm run dev",
    "prisma:migrate": "cd backend && npx prisma migrate dev",
    "prisma:generate": "cd backend && npx prisma generate"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}